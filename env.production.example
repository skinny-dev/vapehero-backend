# Runflare checklist (set these in the portal env for the API service — do not commit real .env):
# - NODE_ENV=production   (required: dev OTP bypass off, stricter rate limits, safer errors)
# - PORT=8080             (must match Kubernetes "Target port" / what nginx forwards to)
# - REDIS_URL=…           (use Runflare Redis service URL — NOT redis://localhost:6379)
# - TRUST_PROXY_HOPS=1    (already default in code if unset)
#
# If https://api…/ returns 502 for / and /health: container is not reachable.
# Typical causes: PORT mismatch (3001 vs target 8080), wrong start command, crash on boot.
DATABASE_URL=postgresql://postgres:PASSWORD@remote-asiatech.runflare.com:31337/DATABASE_NAME
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=365d
REDIS_URL=redis://default:PASSWORD@vph-luu-service:6379/0
KAVENEGAR_API_KEY=your-kavenegar-api-key
KAVENEGAR_OTP_TEMPLATE=vapehero-otp
KAVENEGAR_SENDER=10004346
SMS_TEST_MODE=false
PORT=8080
NODE_ENV=production
# Required behind Runflare proxy so express-rate-limit accepts X-Forwarded-For
TRUST_PROXY_HOPS=1
FRONTEND_URL=https://vapehero.net,https://vapehero.runflare.run,http://vapehero.net,http://localhost:3000,http://localhost:5173
BACKEND_URL=https://api.vapehero.net,https://api.vapehero.runflare.run
