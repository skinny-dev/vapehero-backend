# Database (SQLite for development, PostgreSQL for production)
# For SQLite (development):
DATABASE_URL="file:./dev.db"
# For PostgreSQL (production on Runflare — use your panel credentials, never commit secrets):
# DATABASE_URL="postgresql://postgres:PASSWORD@remote-asiatech.runflare.com:PORT/your_database"

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=7d

# Redis
REDIS_URL=redis://localhost:6379

# SMS Gateway - Kavenegar
KAVENEGAR_API_KEY=your-kavenegar-api-key
KAVENEGAR_OTP_TEMPLATE=vapehero-otp
KAVENEGAR_SENDER=10004346
# Set SMS_TEST_MODE=true to allow dev OTP bypass code (55555) outside production
SMS_TEST_MODE=false

# Cloud Storage (S3)
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_REGION=us-east-1
AWS_S3_BUCKET=vapehero-uploads

# Gemini AI
GEMINI_API_KEY=your-gemini-api-key

# Server
PORT=3001
NODE_ENV=development
# Behind Runflare/nginx: number of reverse proxies in front of Node (default 1)
# TRUST_PROXY_HOPS=1

# CORS & URLs (comma-separated for multiple values)
# FRONTEND_URL = allowed origins for CORS (where your frontend is hosted)
FRONTEND_URL=https://vapehero.net,https://vapehero.runflare.run,http://vapehero.net,http://localhost:3000,http://localhost:5173
# BACKEND_URL = API base URL(s) - frontend uses one to call the API
BACKEND_URL=https://api.vapehero.net,https://api.vapehero.runflare.run
